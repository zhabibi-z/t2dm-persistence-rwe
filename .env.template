# T2DM Persistence RWE — environment variables
# Copy to .env and fill in values (never commit .env to git)

GROQ_API_KEY=your_groq_api_key_here

# Neo4j (optional — only needed if using graph module)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# Synthea
SYNTHEA_PATIENT_COUNT=5000
SYNTHEA_SEED=42

# Paths (override if needed)
DATA_DIR=data
OMOP_DB_PATH=data/omop/omop.duckdb
SYNTHEA_OUTPUT_DIR=data/synthea_output
